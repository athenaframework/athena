# ============================================
# ATHENA — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# LLM Provider (pick one)
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Bot integrations (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
ALLOWED_USERS=

# Dashboard (set these on Railway after deploy)
# VITE_API_URL=https://your-app.up.railway.app
# VITE_WS_URL=wss://your-app.up.railway.app/ws/dashboard

# CORS (set to your Vercel landing page URL)
# CORS_ORIGIN=https://your-landing.vercel.app
